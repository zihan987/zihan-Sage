{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SageAI",
  "version": "1.0.1",
  "identifier": "com.sage.desktop",
  "build": {
    "beforeDevCommand": "cd ui && npm run dev",
    "beforeBuildCommand": "cd ui && npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "SageAI",
        "width": 1024,
        "height": 768,
        "minWidth": 1024,
        "minHeight": 768
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "category": "Productivity",
    "copyright": "",
    "externalBin": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "longDescription": "",
    "macOS": {
      "entitlements": "Entitlements.plist",
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null,
      "dmg": {
        "windowSize": {
          "width": 600,
          "height": 400
        },
        "appPosition": {
          "x": 160,
          "y": 200
        },
        "applicationFolderPosition": {
          "x": 460,
          "y": 200
        }
      }
    },
    "resources": [
      "../../skills",
      "../../../mcp_servers",
      "sidecar",
      "../../wiki"
    ],
    "shortDescription": "",
    "targets": [
      "app",
      "dmg",
      "nsis",
      "msi",
      "deb"
      ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": {
        "language": "zh-CN",
        "dialogImagePath": "icons/icon.png"
      },
      "nsis": {
        "languages": ["SimpChinese"],
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine"
      }
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  },
  "plugins": {
    "shell": {
      "open": "^((mailto:\\w+)|(tel:\\w+)|(https?://\\S+)|(file://\\S+)|(/[^\\s]+)|([a-zA-Z]:[\\\\/][^\\s]+)).*$"
    },
    "updater": {
      "endpoints": [
        "https://api.zavixai.com/api/system/version/check"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVGQzk1MzUxMUMwNkI4ODUKUldTRnVBWWNVVlBKNzVSOEFrQWhlcDBySkZHRUVzL1pvaldpWXc5OGU1SytxbC9MWnd1YVhDSG4K"
    }
  }
}
